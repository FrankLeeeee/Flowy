{
  "name": "my-hub",
  "private": true,
  "workspaces": ["backend", "frontend", "runner"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend && npm run build --workspace=runner",
    "test": "vitest run"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vitest": "^3.2.4"
  }
}
